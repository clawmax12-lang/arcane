# Trade — environment variable template (SAFE to commit; no real values).
# Copy to .env and fill in during CLAUDE.md §0.5 onboarding. Never put real keys here.

# ── Tier 1 data-stack ──
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
APIFY_TOKEN=
POLYGON_API_KEY=

# ── Broker (Alpaca paper) — executor/scheduler via alpaca-py SDK ──
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# ── LLM (slow-loop agentic calls from Python) ──
ANTHROPIC_API_KEY=

# ── Macro / research ──
FRED_API_KEY=
GITHUB_TOKEN=

# ── Alerts ──
DISCORD_WEBHOOK_URL=
# Telegram (the §5 Murphy pager + §1.1 daily-report channel; disaster-recovery transport).
# Bot @Traderexperimentbot. CHAT_ID auto-resolves via getUpdates if blank (message the bot once).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
